# Réception des messages du formulaire (serveur uniquement)
CONTACT_TO_EMAIL=votre-adresse@gmail.com

# Gmail SMTP + Nodemailer
# Activez la validation en deux étapes puis créez un mot de passe d'application Google.
GMAIL_SMTP_USER=votre-adresse@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Resend API
# Utilisez une adresse expéditrice appartenant à un domaine vérifié dans Resend.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Kalawang <contact@votre-domaine.fr>
